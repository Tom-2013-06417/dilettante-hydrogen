# Copy to .env for local development.
# After linking your store, run `npx shopify hydrogen env pull` to populate Shopify vars.

# Required locally. Use a long random string in production (e.g. `openssl rand -hex 32`).
SESSION_SECRET=

# Populated by `shopify hydrogen env pull` after linking:
# PUBLIC_STORE_DOMAIN=
# PUBLIC_STOREFRONT_API_TOKEN=
# PUBLIC_STOREFRONT_ID=
# PUBLIC_CHECKOUT_DOMAIN=
# PRIVATE_STOREFRONT_API_TOKEN=
# PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=
# PUBLIC_CUSTOMER_ACCOUNT_API_URL=
# SHOP_ID=
